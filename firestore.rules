// =====================================================
//  FIRESTORE SECURITY RULES
//  Proyecto: physicsnoteslab-a23d9
//  Copiar en: Firebase Console → Firestore → Rules
// =====================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email in [
          "pgalvisg8156@universidadean.edu.co",
          "tomassantiagogalvisbarrera3@gmail.com"
        ] || request.auth.token.admin == true
      );
    }

    function isOwnerOrAdmin(uid) {
      return request.auth != null && (
        request.auth.uid == uid || isAdmin()
      );
    }

    // ─── Metadatos centralizados de las materias ───
    match /subjectsMeta/{subjectId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ─── Backups ───
    match /subjectsMetaBackups/{docId} {
      allow read, write: if isAdmin();
    }

    // ─── Datos del usuario ───
    match /users/{uid} {
      allow read, write: if isOwnerOrAdmin(uid);

      // Metadatos de materia (estado, nota, profesor, periodo)
      match /subjects/{subjectId} {
        allow read, write: if isOwnerOrAdmin(uid);
        match /{subcollection}/{docId} {
          allow read, write: if isOwnerOrAdmin(uid);
        }
      }

      // Materias personalizadas por semestre (CRUD de asignaturas)
      match /semSubjects/{semId} {
        allow read, write: if isOwnerOrAdmin(uid);
      }

      // Semestres personalizados creados por el usuario (Sem XI, XII…)
      match /customSemesters/{docId} {
        allow read, write: if isOwnerOrAdmin(uid);
      }

      // Eventos del calendario académico
      match /events/{eventId} {
        allow read, write: if isOwnerOrAdmin(uid);
      }

      // Legacy — alias de semSubjects usado antes
      match /semesters/{semId} {
        allow read, write: if isOwnerOrAdmin(uid);
        match /subjects/{subjectId} {
          allow read, write: if isOwnerOrAdmin(uid);
        }
      }
    }
  }
}
